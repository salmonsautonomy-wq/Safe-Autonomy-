Audit Layer (DALG Logging)

# backend/audit/logger.py
import time
import json

class AuditLogger:
    def __init__(self):
        self.logs = []

    def log(self, data):
        timestamp = time.time()
        entry = {"timestamp": timestamp, "data": data}
        self.logs.append(entry)
        return entry


