Governance Layer (HOOP)

# backend/governance/rules.py
class HOOP:
    def __init__(self, rules):
        self.rules = rules

    def enforce(self, task):
        # Return True if task passes safety & scope checks
        for rule in self.rules:
            if not rule(task):
                return False
        return True

# Example rule
def no_unsafe_words(task):
    unsafe = ["hack", "exploit"]
    return not any(word in task["prompt"] for word in unsafe)


