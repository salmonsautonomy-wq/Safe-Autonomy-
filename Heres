Integrity Layer (Hash Chaining)

# backend/integrity/chain.py
import hashlib

class IntegrityChain:
    def __init__(self):
        self.chain = []

    def add(self, data):
        prev_hash = self.chain[-1]["hash"] if self.chain else ""
        combined = json.dumps(data, sort_keys=True) + prev_hash
        hash_val = hashlib.sha256(combined.encode()).hexdigest()
        self.chain.append({"data": data, "hash": hash_val})
        return hash_val


